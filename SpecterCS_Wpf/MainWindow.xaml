<!--Echo1_RcsSimulator\Echo1_Wpf\MainWindow.xaml-->
<Window x:Class="Echo1.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Echo-1 RCS Simulator"
        Background="#0A0E14"
        WindowState="Maximized"
        KeyDown="Window_KeyDown">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Viewport injected from code-behind -->
        <Border x:Name="ViewportHost" Grid.Column="0" Background="#080C12"/>

        <DockPanel Grid.Column="1" Background="#0D1117" LastChildFill="True">
            <GroupBox Header="Radar" DockPanel.Dock="Top"
                Foreground="#8BA5C9" Margin="8">
                <StackPanel>
                    <Label Content="Frequency (GHz)" Foreground="#8BA5C9"/>
                    <Slider x:Name="FreqSlider" Minimum="1" Maximum="40" Value="10"
                  ValueChanged="FreqSlider_Changed"/>
                    <Label Content="Azimuth (°)" Foreground="#8BA5C9"/>
                    <Slider x:Name="AzSlider" Minimum="-180" Maximum="180" Value="0"
                  ValueChanged="AzSlider_Changed"/>
                    <Label Content="Elevation (°)" Foreground="#8BA5C9"/>
                    <Slider x:Name="ElSlider" Minimum="-90" Maximum="90" Value="0"
                  ValueChanged="ElSlider_Changed"/>
                    <CheckBox x:Name="SweepToggle" Content="Auto Sweep"
                    Foreground="#8BA5C9" Margin="0,8,0,0"
                    Checked="Sweep_Checked" Unchecked="Sweep_Checked"/>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="RCS" DockPanel.Dock="Top"
                Foreground="#8BA5C9" Margin="8">
                <StackPanel>
                    <Label x:Name="RcsDbLabel" Content="— dBsm"
                 FontSize="28" FontWeight="Bold"
                 Foreground="#4FC3F7" HorizontalAlignment="Center"/>
                    <Label x:Name="RcsM2Label" Content="— m²"
                 FontSize="14" Foreground="#8BA5C9"
                 HorizontalAlignment="Center"/>
                </StackPanel>
            </GroupBox>
            <Button Content="Load OBJ / STL" DockPanel.Dock="Bottom"
              Margin="8" Padding="0,8" Click="LoadModel_Click"
              Background="#1A2744" Foreground="White"/>
        </DockPanel>
    </Grid>
</Window>