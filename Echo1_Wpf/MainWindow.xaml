<Window x:Class="Echo1.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="http://helix-toolkit.org/wpf"
        Title="Echo-1 RCS Simulator" Background="#0A0E14"
        WindowState="Maximized">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- 3D Viewport -->
        <h:HelixViewport3D x:Name="Viewport"
                       Grid.Column="0"
                       Background="#080C12"
                       ZoomExtentsWhenLoaded="True"
                       IsManipulationEnabled="True"
                       CameraMode="Inspect">
            <h:HelixViewport3D.Camera>
                <PerspectiveCamera x:Name="MainCamera"
                           Position="0,0,50"
                           LookDirection="0,0,-1"
                           UpDirection="0,1,0"
                           FieldOfView="60"/>
            </h:HelixViewport3D.Camera>
            <h:SunLight/>
            <ModelVisual3D x:Name="MeshVisual"/>
        </h:HelixViewport3D>

        <!-- Control Panel -->
        <DockPanel Grid.Column="1" Background="#0D1117" LastChildFill="True">

            <!-- Radar Sweep -->
            <GroupBox Header="Radar" DockPanel.Dock="Top" Foreground="#8BA5C9" Margin="8">
                <StackPanel>
                    <Label Content="Frequency (GHz)" Foreground="#8BA5C9"/>
                    <Slider x:Name="FreqSlider" Minimum="1" Maximum="40" Value="10"
                  ValueChanged="FreqSlider_Changed" TickFrequency="1"/>
                    <Label Content="Azimuth (°)" Foreground="#8BA5C9"/>
                    <Slider x:Name="AzSlider" Minimum="-180" Maximum="180"
                  ValueChanged="AzSlider_Changed"/>
                    <Label Content="Elevation (°)" Foreground="#8BA5C9"/>
                    <Slider x:Name="ElSlider" Minimum="-90" Maximum="90"
                  ValueChanged="ElSlider_Changed"/>
                    <CheckBox x:Name="SweepToggle" Content="Auto Sweep"
                    Foreground="#8BA5C9" Checked="Sweep_Checked"/>
                </StackPanel>
            </GroupBox>

            <!-- RCS Readout -->
            <GroupBox Header="RCS" DockPanel.Dock="Top" Foreground="#8BA5C9" Margin="8">
                <StackPanel>
                    <Label x:Name="RcsDbLabel" FontSize="28" FontWeight="Bold"
                 Foreground="#4FC3F7" HorizontalAlignment="Center"/>
                    <Label x:Name="RcsM2Label" FontSize="14" Foreground="#8BA5C9"
                 HorizontalAlignment="Center"/>
                </StackPanel>
            </GroupBox>

            <!-- Load Model -->
            <Button Content="Load OBJ / STL" DockPanel.Dock="Bottom"
              Margin="8" Click="LoadModel_Click" Background="#1A2744" Foreground="White"/>
        </DockPanel>
    </Grid>
</Window>