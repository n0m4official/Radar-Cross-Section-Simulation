<!--Echo1_RcsSimulator\Echo1_Wpf\MainWindow.xaml-->
<Window x:Class="Echo1.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SpecterCS — RCS Simulator"
        Background="#0A0E14"
        WindowState="Maximized"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style x:Key="PanelLabel" TargetType="Label">
            <Setter Property="Foreground" Value="#8BA5C9"/>
            <Setter Property="Padding"    Value="0,2,0,0"/>
            <Setter Property="FontSize"   Value="11"/>
        </Style>
        <Style x:Key="ValueLabel" TargetType="Label">
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="FontSize"   Value="11"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="Label">
            <Setter Property="Foreground"   Value="#C8D8EE"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Padding"      Value="0,4,0,2"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background"   Value="#1A2744"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="Padding"      Value="6,5"/>
            <Setter Property="BorderBrush"  Value="#2A3F6A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"       Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <!-- 3D viewport -->
            <ColumnDefinition Width="340"/>
            <!-- Control panel -->
        </Grid.ColumnDefinitions>

        <!-- 3D Viewport (injected from code-behind) -->
        <Border x:Name="ViewportHost" Grid.Column="0" Background="#080C12"/>

        <!-- Control Panel -->
        <ScrollViewer Grid.Column="1" Background="#0D1117" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,16">

                <!-- ── File ─────────────────────────────────────────────── -->
                <GroupBox Header="Model" Foreground="#8BA5C9" Margin="8,8,8,4">
                    <StackPanel>
                        <Button x:Name="BtnLoad" Content="Load OBJ / STL…"
                                Style="{StaticResource ActionButton}"
                                Margin="0,4,0,4" Padding="0,8"
                                Click="LoadModel_Click"/>
                        <Label x:Name="MeshInfoLabel" Content="No model loaded"
                               Style="{StaticResource ValueLabel}" FontSize="10"
                               HorizontalAlignment="Center"/>
                    </StackPanel>
                </GroupBox>

                <!-- ── Radar ─────────────────────────────────────────────── -->
                <GroupBox Header="Radar" Foreground="#8BA5C9" Margin="8,4,8,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="52"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <!-- Frequency -->
                        <Label Grid.Row="0" Grid.Column="0" Content="Frequency (GHz)"
                               Style="{StaticResource PanelLabel}"/>
                        <Label x:Name="FreqValueLabel" Grid.Row="0" Grid.Column="1"
                               Style="{StaticResource ValueLabel}" HorizontalAlignment="Right"/>
                        <Slider x:Name="FreqSlider" Grid.Row="1" Grid.ColumnSpan="2"
                                Minimum="1" Maximum="40" Value="10" TickFrequency="1"
                                ValueChanged="FreqSlider_Changed" Margin="0,0,0,4"/>

                        <!-- Band selector (convenience buttons) -->
                        <WrapPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,0,0,6">
                            <Button Content="L 1.3" Tag="1.3"  Style="{StaticResource ActionButton}" Margin="2" Padding="4,3" Click="BandPreset_Click"/>
                            <Button Content="S 3.0" Tag="3.0"  Style="{StaticResource ActionButton}" Margin="2" Padding="4,3" Click="BandPreset_Click"/>
                            <Button Content="C 5.5" Tag="5.5"  Style="{StaticResource ActionButton}" Margin="2" Padding="4,3" Click="BandPreset_Click"/>
                            <Button Content="X 10"  Tag="10.0" Style="{StaticResource ActionButton}" Margin="2" Padding="4,3" Click="BandPreset_Click"/>
                            <Button Content="Ku 16" Tag="16.0" Style="{StaticResource ActionButton}" Margin="2" Padding="4,3" Click="BandPreset_Click"/>
                            <Button Content="Ka 35" Tag="35.0" Style="{StaticResource ActionButton}" Margin="2" Padding="4,3" Click="BandPreset_Click"/>
                        </WrapPanel>

                        <!-- Azimuth -->
                        <Label Grid.Row="3" Grid.Column="0" Content="Azimuth (°)"
                               Style="{StaticResource PanelLabel}"/>
                        <Label x:Name="AzValueLabel" Grid.Row="3" Grid.Column="1"
                               Style="{StaticResource ValueLabel}" HorizontalAlignment="Right"/>
                        <Slider x:Name="AzSlider" Grid.Row="4" Grid.ColumnSpan="2"
                                Minimum="-180" Maximum="180" Value="0"
                                ValueChanged="AzSlider_Changed" Margin="0,0,0,4"/>

                        <!-- Elevation -->
                        <Label Grid.Row="5" Grid.Column="0" Content="Elevation (°)"
                               Style="{StaticResource PanelLabel}"/>
                        <Label x:Name="ElValueLabel" Grid.Row="5" Grid.Column="1"
                               Style="{StaticResource ValueLabel}" HorizontalAlignment="Right"/>
                        <Slider x:Name="ElSlider" Grid.Row="6" Grid.ColumnSpan="2"
                                Minimum="-90" Maximum="90" Value="0"
                                ValueChanged="ElSlider_Changed"/>
                    </Grid>
                </GroupBox>

                <!-- ── Polarisation ─────────────────────────────────────── -->
                <GroupBox Header="Polarisation" Foreground="#8BA5C9" Margin="8,4,8,4">
                    <WrapPanel>
                        <RadioButton x:Name="PolVV" Content="VV" IsChecked="True"
                                     Foreground="#8BA5C9" Margin="4" Checked="Pol_Changed"/>
                        <RadioButton x:Name="PolHH" Content="HH"
                                     Foreground="#8BA5C9" Margin="4" Checked="Pol_Changed"/>
                        <RadioButton x:Name="PolHV" Content="HV (cross)"
                                     Foreground="#8BA5C9" Margin="4" Checked="Pol_Changed"/>
                    </WrapPanel>
                </GroupBox>

                <!-- ── RCS Results ──────────────────────────────────────── -->
                <GroupBox Header="RCS Result" Foreground="#8BA5C9" Margin="8,4,8,4">
                    <StackPanel>
                        <Label x:Name="RcsDbLabel" Content="— dBsm"
                               FontSize="30" FontWeight="Bold"
                               Foreground="#4FC3F7" HorizontalAlignment="Center"/>
                        <Label x:Name="RcsM2Label" Content="— m²"
                               FontSize="13" Foreground="#8BA5C9"
                               HorizontalAlignment="Center"/>
                        <Separator Background="#1A2744" Margin="4"/>
                        <Grid Margin="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Label Grid.Row="0" Grid.Column="0" Content="PO only"
                                   Style="{StaticResource PanelLabel}" FontSize="10"/>
                            <Label x:Name="PoDbLabel" Grid.Row="0" Grid.Column="1"
                                   Style="{StaticResource ValueLabel}" FontSize="10"
                                   HorizontalAlignment="Right" Content="—"/>
                            <Label Grid.Row="1" Grid.Column="0" Content="Edge diffraction"
                                   Style="{StaticResource PanelLabel}" FontSize="10"/>
                            <Label x:Name="EdgeDbLabel" Grid.Row="1" Grid.Column="1"
                                   Style="{StaticResource ValueLabel}" FontSize="10"
                                   HorizontalAlignment="Right" Content="—"/>
                        </Grid>
                        <!-- Heatmap legend strip -->
                        <Border Height="12" Margin="4,4,4,0" CornerRadius="2"
                                x:Name="HeatLegend" ToolTip="Facet RCS contribution colour map"/>
                        <Grid Margin="4,0,4,2">
                            <Label Content="Low" Style="{StaticResource PanelLabel}"
                                   FontSize="9" HorizontalAlignment="Left"/>
                            <Label Content="High" Style="{StaticResource PanelLabel}"
                                   FontSize="9" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- ── Sweep ────────────────────────────────────────────── -->
                <GroupBox Header="Sweep" Foreground="#8BA5C9" Margin="8,4,8,4">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="Sweep rate (°/s)"
                                   Style="{StaticResource PanelLabel}"/>
                            <Label x:Name="SweepRateLabel" Grid.Column="1"
                                   Style="{StaticResource ValueLabel}"
                                   HorizontalAlignment="Right" Content="30"/>
                        </Grid>
                        <Slider x:Name="SweepRateSlider" Minimum="1" Maximum="180" Value="30"
                                ValueChanged="SweepRate_Changed" Margin="0,0,0,6"/>

                        <CheckBox x:Name="SweepToggle" Content="Auto-sweep azimuth"
                                  Foreground="#8BA5C9" Margin="0,2,0,4"
                                  Checked="Sweep_Checked" Unchecked="Sweep_Checked"/>

                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Compute full sweep"
                                    Style="{StaticResource ActionButton}"
                                    Margin="0,0,3,0" Padding="0,6"
                                    Click="ComputeFullSweep_Click"/>
                            <Button Grid.Column="1" Content="Export CSV…"
                                    Style="{StaticResource ActionButton}"
                                    Margin="3,0,0,0" Padding="0,6"
                                    Click="ExportCsv_Click"
                                    x:Name="BtnExport" IsEnabled="False"/>
                        </Grid>

                        <!-- Mini polar display (custom drawn Canvas) -->
                        <Canvas x:Name="PolarCanvas" Height="200" Margin="4,6,4,0"
                                Background="#080C12" ClipToBounds="True"/>
                    </StackPanel>
                </GroupBox>

                <!-- ── Frequency sweep ──────────────────────────────────── -->
                <GroupBox Header="Frequency sweep" Foreground="#8BA5C9" Margin="8,4,8,4">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Label Grid.Row="0" Grid.Column="0" Content="Start GHz"
                                   Style="{StaticResource PanelLabel}"/>
                            <Label Grid.Row="0" Grid.Column="1" Content="Stop GHz"
                                   Style="{StaticResource PanelLabel}"/>
                            <TextBox x:Name="FreqSweepStart" Grid.Row="1" Grid.Column="0"
                                     Text="1" Background="#0A0E14" Foreground="#8BA5C9"
                                     BorderBrush="#1A2744" Margin="0,0,3,0"/>
                            <TextBox x:Name="FreqSweepStop" Grid.Row="1" Grid.Column="1"
                                     Text="18" Background="#0A0E14" Foreground="#8BA5C9"
                                     BorderBrush="#1A2744"/>
                        </Grid>
                        <Button Content="Run frequency sweep"
                                Style="{StaticResource ActionButton}"
                                Margin="0,6,0,0" Padding="0,6"
                                Click="RunFreqSweep_Click"/>
                        <Canvas x:Name="FreqCanvas" Height="120" Margin="4,4,4,0"
                                Background="#080C12" ClipToBounds="True"/>
                    </StackPanel>
                </GroupBox>

                <!-- ── Material Assignment ──────────────────────────────── -->
                <GroupBox Header="Materials" Foreground="#8BA5C9" Margin="8,4,8,4">
                    <StackPanel>
                        <Label Style="{StaticResource PanelLabel}" FontSize="10"
                               Content="Assign coating to selected region (bounding box):"
                               ContentStringFormat="{}{0}"/>
                        <ComboBox x:Name="MaterialCombo" Margin="0,4,0,0"
                                  Background="#0A0E14" Foreground="#8BA5C9"
                                  BorderBrush="#1A2744"
                                  SelectionChanged="MaterialCombo_Changed">
                            <ComboBoxItem Content="PEC (default)" Tag="PEC" IsSelected="True"/>
                            <ComboBoxItem Content="Carbon foam RAM 10mm"      Tag="CarbonFoam"/>
                            <ComboBoxItem Content="Ferrite tile 3mm"          Tag="Ferrite"/>
                            <ComboBoxItem Content="Dielectric coating 5mm"    Tag="Dielectric"/>
                        </ComboBox>
                        <Button Content="Apply to whole model"
                                Style="{StaticResource ActionButton}"
                                Margin="0,6,0,0" Padding="0,6"
                                Click="ApplyMaterial_Click"/>
                        <Label x:Name="MaterialStatusLabel"
                               Style="{StaticResource ValueLabel}" FontSize="10"
                               HorizontalAlignment="Center" Content=""/>
                    </StackPanel>
                </GroupBox>

                <!-- ── Display ──────────────────────────────────────────── -->
                <GroupBox Header="Display" Foreground="#8BA5C9" Margin="8,4,8,8">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="Heatmap min (dBsm)"
                                   Style="{StaticResource PanelLabel}"/>
                            <TextBox x:Name="HeatMinBox" Grid.Column="1" Text="-40"
                                     Background="#0A0E14" Foreground="#8BA5C9"
                                     BorderBrush="#1A2744"
                                     LostFocus="HeatRange_Changed"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="Heatmap max (dBsm)"
                                   Style="{StaticResource PanelLabel}"/>
                            <TextBox x:Name="HeatMaxBox" Grid.Column="1" Text="10"
                                     Background="#0A0E14" Foreground="#8BA5C9"
                                     BorderBrush="#1A2744"
                                     LostFocus="HeatRange_Changed"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
