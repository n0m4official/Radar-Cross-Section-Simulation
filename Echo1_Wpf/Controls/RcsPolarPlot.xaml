<UserControl x:Class="Echo1_Wpf.Controls.RcsPolarPlot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Echo1_Wpf.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="#0D1117">
        <Canvas x:Name="PlotCanvas" SizeChanged="PlotCanvas_SizeChanged"/>
        <TextBlock Text="RCS Polar Map (dBsm)" Foreground="Gray" HorizontalAlignment="Center" Margin="5"/>
    </Grid>
</UserControl>
